[wolvenkit]
# Path to WolvenKit CLI executable
cli_path = "C:\\Tools\\WolvenKit\\WolvenKit.CLI.exe"

[paths]
# Path to Cyberpunk 2077 game directory
game_dir = "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Cyberpunk 2077"
# Working directory for extracted files
work_dir = "./work"
# Output directory for final mod package
output_dir = "./output"

[mod]
# Mod metadata for info.json
name = "CP2077ProfanityFilter"
version = "1.0.0"
description = "Replaces profane words in English localization with asterisks"

[profanity]
# Path to profanity wordlist
wordlist = "./profanity_list.txt"

[performance]
# Number of parallel workers for CR2W conversion (cr2w -s and cr2w -d)
# Increase for faster extraction/repacking on machines with more CPU cores
workers = 8

[audio]
# Path to sound2wem batch script (OGG → WEM conversion via Wwise)
sound2wem_script = "C:\\Tools\\sound2wem\\zSound2wem.cmd"
# Path to Audiokinetic Wwise installation directory
wwise_dir = "C:\\Audiokinetic\\Wwise2019.2.15.7667"
# Whisper model size for monkeyplug voice pipeline: tiny, base, small, medium, large
whisper_model = "base"
# Number of parallel monkeyplug instances for voice pipeline (GPU-bound — tune based on VRAM)
monkeyplug_workers = 6

[radio]
# Path to a custom curated radio track list (JSON array of {hash, station, title} objects).
# If not set, the bundled data/radio_tracks.json placeholder is used.
# radio_tracks_file = "C:\\path\\to\\my_radio_tracks.json"
